# config.env — UX Improvement 파이프라인 설정
# source 해서 사용. 환경변수로 오버라이드 가능.

# ── Phase별 타임아웃 (초) — 매일 1회 실행 ────────────────
PHASE1_TIMEOUT="${PHASE1_TIMEOUT:-14400}"           # 4h — UX Improver
PHASE2_TIMEOUT="${PHASE2_TIMEOUT:-7200}"            # 2h — UX Reviewer
PHASE3_FIX_TIMEOUT="${PHASE3_FIX_TIMEOUT:-5400}"    # 1.5h — Fixer 1회
PHASE3_REVIEW_TIMEOUT="${PHASE3_REVIEW_TIMEOUT:-3600}" # 1h — Re-reviewer 1회
TOTAL_TIMEOUT="${TOTAL_TIMEOUT:-50400}"             # 14h — 전체

# ── Round Loop ───────────────────────────────────────────
UX_SLA_TARGET="${UX_SLA_TARGET:-7.0}"
MAX_ROUNDS="${MAX_ROUNDS:-5}"                      # 매일 1회이므로 최대 5라운드
PHASE_EVAL_TIMEOUT="${PHASE_EVAL_TIMEOUT:-3600}"   # 1h
MIN_SCORE_IMPROVEMENT="${MIN_SCORE_IMPROVEMENT:-0.3}"

# ── 수정 루프 ────────────────────────────────────────────
MAX_FIX_CYCLES="${MAX_FIX_CYCLES:-5}"              # daily-improvement와 동일

# ── 브랜치 ────────────────────────────────────────────────
BRANCH_PREFIX="${BRANCH_PREFIX:-ux-improve}"
BASE_BRANCH="${BASE_BRANCH:-master}"

# ── 이슈 ──────────────────────────────────────────────────
STALE_ISSUE_DAYS="${STALE_ISSUE_DAYS:-7}"
MAX_ISSUES_PER_ROUND="${MAX_ISSUES_PER_ROUND:-10}" # 매일 1회이므로 충분히 처리

# ── 히스토리 ──────────────────────────────────────────────
HISTORY_DAYS="${HISTORY_DAYS:-7}"
HISTORY_FILE="${PROJECT_ROOT:-.}/logs/ux-improvement/history.jsonl"

# ── 자동 머지 ─────────────────────────────────────────────
AUTO_MERGE="${AUTO_MERGE:-true}"                   # 안전 조건 충족 시 자동 머지

# ── 안전 경로 (자동 머지 허용) ─────────────────────────────
SAFE_PATHS="commands/ guides/ templates/ presets/ agents/ skills/"

# ── 세션 복원 설정 ────────────────────────────────────────
SESSION_RETRY_DELAY="${SESSION_RETRY_DELAY:-300}"
SESSION_MAX_RETRIES="${SESSION_MAX_RETRIES:-3}"

# ── GitHub CLI 설정 ───────────────────────────────────────
GH_TIMEOUT="${GH_TIMEOUT:-15000}"

# ── 텔레그램 ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-}"
