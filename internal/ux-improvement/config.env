# config.env — UX Improvement 파이프라인 설정
# source 해서 사용. 환경변수로 오버라이드 가능.

# ── Phase별 타임아웃 (초) — 3시간 주기에 맞춰 축소 ──────
PHASE1_TIMEOUT="${PHASE1_TIMEOUT:-3600}"           # 1h — UX Improver
PHASE2_TIMEOUT="${PHASE2_TIMEOUT:-1800}"            # 30m — UX Reviewer
PHASE3_FIX_TIMEOUT="${PHASE3_FIX_TIMEOUT:-1800}"    # 30m — Fixer 1회
PHASE3_REVIEW_TIMEOUT="${PHASE3_REVIEW_TIMEOUT:-900}" # 15m — Re-reviewer 1회
TOTAL_TIMEOUT="${TOTAL_TIMEOUT:-9000}"              # 2.5h — 전체

# ── Round Loop ───────────────────────────────────────────
UX_SLA_TARGET="${UX_SLA_TARGET:-7.0}"
MAX_ROUNDS="${MAX_ROUNDS:-2}"                      # 3시간 주기이므로 2라운드가 현실적
PHASE_EVAL_TIMEOUT="${PHASE_EVAL_TIMEOUT:-1800}"   # 30m
MIN_SCORE_IMPROVEMENT="${MIN_SCORE_IMPROVEMENT:-0.3}"

# ── 수정 루프 ────────────────────────────────────────────
MAX_FIX_CYCLES="${MAX_FIX_CYCLES:-3}"              # 시간 제약으로 3회

# ── 브랜치 ────────────────────────────────────────────────
BRANCH_PREFIX="${BRANCH_PREFIX:-ux-improve}"
BASE_BRANCH="${BASE_BRANCH:-master}"

# ── 이슈 ──────────────────────────────────────────────────
STALE_ISSUE_DAYS="${STALE_ISSUE_DAYS:-7}"          # UX 이슈는 더 빠른 주기
MAX_ISSUES_PER_ROUND="${MAX_ISSUES_PER_ROUND:-5}"  # 3시간 주기에 맞춰 축소

# ── 히스토리 ──────────────────────────────────────────────
HISTORY_DAYS="${HISTORY_DAYS:-7}"
HISTORY_FILE="${PROJECT_ROOT:-.}/logs/ux-improvement/history.jsonl"

# ── 자동 머지 ─────────────────────────────────────────────
AUTO_MERGE="${AUTO_MERGE:-true}"                   # 안전 조건 충족 시 자동 머지

# ── 안전 경로 (자동 머지 허용) ─────────────────────────────
SAFE_PATHS="commands/ guides/ templates/ presets/ agents/ skills/"

# ── 세션 복원 설정 ────────────────────────────────────────
SESSION_RETRY_DELAY="${SESSION_RETRY_DELAY:-300}"
SESSION_MAX_RETRIES="${SESSION_MAX_RETRIES:-3}"

# ── GitHub CLI 설정 ───────────────────────────────────────
GH_TIMEOUT="${GH_TIMEOUT:-15000}"

# ── 텔레그램 ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-}"
