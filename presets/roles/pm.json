{
  "name": "pm",
  "displayName": "PM / 기획자",
  "description": "프로젝트 매니저, 기획자를 위한 Claude Code 설정",
  "category": "role",
  "agents": [
    {
      "template": "doc-reviewer-kr",
      "config": { "model": "sonnet", "tools": ["Read", "Grep", "Glob"] }
    }
  ],
  "orchestration": {
    "enabled": true,
    "steps": [
      {
        "phase": "문서 검토",
        "agent": "doc-reviewer-kr",
        "trigger": "기획서/PRD 작성 후",
        "description": "명확성/완전성/실현가능성 관점에서 문서를 검토합니다"
      }
    ]
  },
  "skills": ["prd-writer", "meeting-notes", "issue-tracker"],
  "commands": ["daily-report", "write-prd"],
  "rules": { "core": true, "doc_standards": true },
  "hooks": { "doc_format": true, "checklist_auto": true },
  "workflow": "pm-agile",
  "guides": ["common", "pm"],
  "claudeMd": { "language": "korean" },
  "workflowSteps": [
    "요구사항 분석: 사용자 스토리 정의",
    "기획서 작성: PRD/기능 명세서 초안",
    "검토: 문서 리뷰 + 피드백 반영",
    "이슈 관리: 티켓 생성 + 우선순위 지정",
    "추적: 진행 상황 모니터링 + 리포트"
  ],
  "roleDescription": "프로젝트 기획, 요구사항 관리, 이슈 추적, 문서 작성",
  "coreRules": {
    "docWriting": [
      "명확하고 간결한 문장 사용",
      "의사결정 사항은 근거와 함께 기록",
      "날짜/버전 명시",
      "체크리스트 활용"
    ],
    "issueManagement": [
      "이슈 제목은 행동 동사로 시작 (예: 추가, 수정, 개선)",
      "우선순위 명시 (P0~P3)",
      "담당자 지정 필수"
    ],
    "dataReport": [
      "수치는 출처와 함께 제시",
      "시각화 자료 적극 활용",
      "주간/월간 정기 리포트 템플릿 사용"
    ]
  }
}
