# config.env — Daily Improvement 파이프라인 설정
# source 해서 사용. 환경변수로 오버라이드 가능.

# ── Phase별 타임아웃 (초) ─────────────────────────────────
PHASE1_TIMEOUT="${PHASE1_TIMEOUT:-14400}"          # 4h — Improver (분석+수정+테스트)
PHASE2_TIMEOUT="${PHASE2_TIMEOUT:-7200}"            # 2h — Reviewer (컨텍스트 읽기+깊이 리뷰)
PHASE3_FIX_TIMEOUT="${PHASE3_FIX_TIMEOUT:-5400}"     # 1.5h — Fixer 세션 1회
PHASE3_REVIEW_TIMEOUT="${PHASE3_REVIEW_TIMEOUT:-3600}" # 1h — Re-reviewer 세션 1회
TOTAL_TIMEOUT="${TOTAL_TIMEOUT:-50400}"              # 14h — 전체 파이프라인

# ── 정책 상수 ────────────────────────────────────────────
MAX_FIX_CYCLES="${MAX_FIX_CYCLES:-5}"        # 안전장치 (실제 종료는 진행도 기반)
CI_WAIT_TIMEOUT="${CI_WAIT_TIMEOUT:-600}"     # CI 완료 대기 최대 시간 (초)
CI_POLL_INTERVAL="${CI_POLL_INTERVAL:-30}"     # CI 폴링 간격 (초)
HISTORY_DAYS="${HISTORY_DAYS:-7}"              # 히스토리 참조 기간 (일)

# ── 브랜치 설정 ──────────────────────────────────────────
BRANCH_PREFIX="${BRANCH_PREFIX:-improve}"
BASE_BRANCH="${BASE_BRANCH:-master}"

# ── GitHub 라벨 ──────────────────────────────────────────
LABELS_REQUIRED="automated improvement quality security performance merge-ready"

# ── Round Loop 설정 ──────────────────────────────────────
SLA_TARGET="${SLA_TARGET:-7.0}"                       # 7영역 평균 목표 (0-10)
MAX_ROUNDS="${MAX_ROUNDS:-0}"                         # 0 = 무제한 (watchdog이 안전장치)
PHASE_EVAL_TIMEOUT="${PHASE_EVAL_TIMEOUT:-3600}"      # 1h — 평가 세션
MIN_SCORE_IMPROVEMENT="${MIN_SCORE_IMPROVEMENT:-0.3}"  # 라운드 간 최소 개선폭

# ── 이슈 관리 설정 ──────────────────────────────────────
STALE_ISSUE_DAYS="${STALE_ISSUE_DAYS:-14}"            # stale 이슈 기준 일수
MAX_ISSUES_PER_ROUND="${MAX_ISSUES_PER_ROUND:-10}"    # 라운드당 최대 이슈 수

# ── 세션 복원 설정 ──────────────────────────────────────
SESSION_RETRY_DELAY="${SESSION_RETRY_DELAY:-300}"      # 5분 — 세션 오류 후 대기 (exponential backoff 기준)
SESSION_MAX_RETRIES="${SESSION_MAX_RETRIES:-3}"        # 세션 오류 최대 재시도

# ── GitHub CLI 설정 ──────────────────────────────────────
GH_TIMEOUT="${GH_TIMEOUT:-15000}"                     # gh CLI 타임아웃 (ms)

# ── 자동 머지 ───────────────────────────────────────────
AUTO_MERGE="${AUTO_MERGE:-false}"                    # true: APPROVED 시 자동 squash merge

# ── 텔레그램 (VPS 환경변수로 설정) ───────────────────────
# export TELEGRAM_BOT_TOKEN="..."
# export TELEGRAM_CHAT_ID="..."
