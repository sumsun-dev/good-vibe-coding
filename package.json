{
  "name": "good-vibe-coding",
  "version": "1.0.0",
  "description": "Virtual AI Team Management Platform — AI 팀을 구성하고 프로젝트를 관리하세요",
  "type": "module",
  "main": "scripts/cli.js",
  "exports": {
    ".": "./src/index.js",
    "./plugin": "./plugin/adapter.js",
    "./lib/core/*": "./scripts/lib/core/*.js",
    "./lib/project/*": "./scripts/lib/project/*.js",
    "./lib/engine/*": "./scripts/lib/engine/*.js",
    "./lib/agent/*": "./scripts/lib/agent/*.js",
    "./lib/llm/*": "./scripts/lib/llm/*.js",
    "./lib/output/*": "./scripts/lib/output/*.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"scripts/**/*.js\" \"src/**/*.js\" \"plugin/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"scripts/**/*.js\" \"src/**/*.js\" \"plugin/**/*.js\" \"tests/**/*.js\""
  },
  "keywords": [
    "claude-code",
    "ai-team",
    "multi-agent",
    "virtual-team",
    "project-management",
    "team-management",
    "code-review",
    "developer-tools",
    "plugin",
    "korean",
    "orchestration",
    "llm"
  ],
  "author": "sumsun-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumsun-dev/good-vibe-coding.git"
  },
  "homepage": "https://github.com/sumsun-dev/good-vibe-coding#readme",
  "bugs": {
    "url": "https://github.com/sumsun-dev/good-vibe-coding/issues"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^3.0.0"
  },
  "files": [
    "src/",
    "scripts/",
    "plugin/",
    "agents/",
    "commands/",
    "guides/",
    "presets/",
    "templates/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
